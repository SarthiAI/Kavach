{
  "name": "kavach-engine",
  "version": "0.1.0",
  "description": "Compiled Rust engine for Kavach, a native Node.js addon exposing the gate evaluator via napi-rs.",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "SEE LICENSE IN ../LICENSE",
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "napi": {
    "name": "kavach-engine",
    "triples": {
      "defaults": false,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  }
}
